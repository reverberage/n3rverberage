{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "nerv",
    "instructions": [
        "AGENTS.md",
        "CONTRIBUTING.md",
        "SECURITY.md",
        "docs/*.md"
    ],
    "agent": {
        "build": {
            "disable": true
        },
        "plan": {
            "disable": true
        }
    },
    "mcp": {
        "nerv-memory": {
            "type": "local",
            "command": [
                "uv",
                "run",
                "nerv-memory"
            ],
            "env": {
                "NERV_AGENT_SOURCE": "opencode"
            }
        },
        "nerv-hub": {
            "type": "local",
            "command": [
                "uv",
                "run",
                "nerv-hub"
            ],
            "env": {
                "NERV_AGENT_SOURCE": "opencode"
            }
        },
        "github": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@github/github-mcp-server"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
            }
        },
        "context7": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp@latest"
            ]
        },
        "sequential-thinking": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-sequential-thinking@latest"
            ]
        }
    },
    "plugin": [
        ".opencode/plugins/nerv-lifecycle.js",
        ".opencode/plugins/nerv-shell-env.js"
    ],
    "tools": {
        "websearch": true
    }
}
