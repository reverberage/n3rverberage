{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "nerv",
  "instructions": ["AGENTS.md"],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },
  "mcp": {
    "nerv-memory": {
      "type": "local",
      "command": ["uv", "run", "nerv-memory"],
      "env": {"NERV_AGENT_SOURCE": "opencode"}
    },
    "nerv-hub": {
      "type": "local",
      "command": ["uv", "run", "nerv-hub"],
      "env": {"NERV_AGENT_SOURCE": "opencode"}
    }
  }
}
