{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "n3rv",
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/*.md"
  ],
  "plugin": [
    ".opencode/plugins/n3rv-lifecycle.js",
    ".opencode/plugins/n3rv-shell-env.js"
  ],
  "tools": {
    "websearch": true
  },
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },
  "mcp": {
    "n3rv-memory": {
      "type": "local",
      "command": ["uv", "run", "n3rv-memory"],
      "environment": {"N3RV_AGENT_SOURCE": "opencode"}
    },
    "n3rv-hub": {
      "type": "local",
      "command": ["uv", "run", "n3rv-hub"],
      "environment": {"N3RV_AGENT_SOURCE": "opencode"}
    }{% for srv in profile_mcp_servers %},
    "{{ srv.name }}": {
      "type": "{{ srv.type }}"{% if srv.command %},
      "command": {{ srv.command | tojson }}{% endif %}{% if srv.url %},
      "url": "{{ srv.url }}"{% endif %}{% if srv.environment %},
      "environment": {{ srv.environment | tojson }}{% endif %}{% if srv.disabled %},
      "enabled": false{% endif %}
    }{% endfor %}
  }
}
