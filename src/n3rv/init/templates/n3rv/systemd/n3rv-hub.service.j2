[Unit]
Description=NERV A2A Hub for {{ project_name }}
After=network.target

[Service]
Type=simple
WorkingDirectory={{ project_root }}
ExecStart={{ nerv_binary }} hub start
Restart=on-failure
RestartSec=5
StandardOutput=append:{{ project_root }}/.nerv/logs/hub.log
StandardError=append:{{ project_root }}/.nerv/logs/hub.log

[Install]
WantedBy=default.target
