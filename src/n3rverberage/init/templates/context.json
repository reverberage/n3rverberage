{
  "description": "Template context schema for n3rverberage init/update.",
  "version": "1.0",
  "variables": {
    "project_name": {
      "type": "string",
      "required": true,
      "description": "Name of the project directory (basename of project root)."
    },
    "stack": {
      "type": "string",
      "required": true,
      "enum": ["python", "node", "go", "generic"],
      "description": "Primary technology stack detected or user-specified."
    },
    "project_root": {
      "type": "string",
      "required": true,
      "description": "Absolute path to the project root directory."
    },
    "n3rverberage_version": {
      "type": "string",
      "required": false,
      "default": "dev",
      "description": "Installed n3rverberage package version."
    },
    "timestamp": {
      "type": "string",
      "required": false,
      "description": "ISO-8601 timestamp of when init/update was run."
    },
    "n3rverberage_binary": {
      "type": "string",
      "required": true,
      "description": "Absolute path to the n3rverberage CLI binary."
    },
    "profile_has_frameworks": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "True if the project has detected frameworks."
    },
    "profile_has_tools": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "True if the project has detected tools/build-systems."
    },
    "model": {
      "type": "string",
      "required": false,
      "default": "qwen3-coder-plus",
      "description": "Default Qwen model ID for opencode (e.g. qwen3-coder-plus)."
    },
    "qwen_base_url": {
      "type": "string",
      "required": false,
      "default": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
      "description": "Base URL for Qwen DashScope API."
    },
    "profile_mcp_servers": {
      "type": "array",
      "required": false,
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "MCP server name." },
          "type": { "type": "string", "description": "Transport type (stdio, http, etc.)." },
          "command": { "type": "string", "description": "Command string or path." },
          "url": { "type": "string", "description": "URL for HTTP-based servers." },
          "environment": { "type": "object", "description": "Key-value env vars for the server." }
        }
      },
      "description": "Detected MCP server configurations."
    },
    "profile_frameworks": {
      "type": "array",
      "required": false,
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Framework name (e.g. fastapi, react)." },
          "category": { "type": "string", "description": "Framework category." },
          "guidance": { "type": "string", "description": "AI guidance text for this framework." }
        }
      },
      "description": "Detected development frameworks."
    },
    "profile_tools": {
      "type": "array",
      "required": false,
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Tool name (e.g. pytest, eslint)." },
          "command": { "type": "string", "description": "Shell command to invoke the tool." },
          "category": { "type": "string", "description": "Tool category (linter, test, etc.)." }
        }
      },
      "description": "Detected development tools."
    },
    "profile_structure": {
      "type": "object",
      "required": false,
      "default": {},
      "properties": {
        "has_src_dir": { "type": "boolean", "description": "Project has a src/ directory." },
        "has_tests_dir": { "type": "boolean", "description": "Project has a tests/ directory." },
        "has_docs_dir": { "type": "boolean", "description": "Project has a docs/ directory." },
        "has_scripts_dir": { "type": "boolean", "description": "Project has a scripts/ directory." },
        "entry_points": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Project entry point files."
        },
        "key_dirs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Significant project directories."
        }
      },
      "description": "Detected project directory structure."
    }
  }
}
