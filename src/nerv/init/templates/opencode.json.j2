{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "nerv",
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/*.md"
  ],
  "plugin": [
    ".opencode/plugins/nerv-lifecycle.js",
    ".opencode/plugins/nerv-shell-env.js"
  ],
  "tools": {
    "websearch": true
  },
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },
  "mcp": {
    "nerv-memory": {
      "type": "local",
      "command": ["uv", "run", "nerv-memory"],
      "env": {"NERV_AGENT_SOURCE": "opencode"}
    },
    "nerv-hub": {
      "type": "local",
      "command": ["uv", "run", "nerv-hub"],
      "env": {"NERV_AGENT_SOURCE": "opencode"}
    }{% for srv in profile_mcp_servers %},
    "{{ srv.name }}": {
      "type": "{{ srv.type }}"{% if srv.command %},
      "command": {{ srv.command | tojson }}{% endif %}{% if srv.url %},
      "url": "{{ srv.url }}"{% endif %}{% if srv.environment %},
      "env": {{ srv.environment | tojson }}{% endif %}{% if srv.disabled %},
      "disabled": true{% endif %}
    }{% endfor %}
  }
}
